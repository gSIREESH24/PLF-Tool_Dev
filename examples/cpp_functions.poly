-- C++ Function Examples - Cross-Language Calls

cpp {
    #include <iostream>
    #include <string>
    using namespace std;
    
    int add(int a, int b) {
        return a + b;
    }
    
    int factorial(int n) {
        if (n <= 1) return 1;
        return n * factorial(n - 1);
    }
    
    double power(double x, int exp) {
        double result = 1.0;
        for (int i = 0; i < exp; i++) {
            result *= x;
        }
        return result;
    }
    
    int main() {
        cout << "C++ functions registered" << endl;
        return 0;
    }
}

python {
    # Call C++ functions from Python
    sum_result = call('add', [15, 25])
    print(f"C++: 15 + 25 = {sum_result}")
    
    fact_5 = call('factorial', [5])
    print(f"C++: 5! = {fact_5}")
    
    pow_result = call('power', [2.0, 10])
    print(f"C++: 2.0^10 = {pow_result}")
}

javascript {
    // Call C++ functions from JavaScript
    let x = call('add', [100, 50]);
    console.log(`C++: 100 + 50 = ${x}`);
    
    let fact = call('factorial', [6]);
    console.log(`C++: 6! = ${fact}`);
}
