-- Math Operations Across Languages

python {
    def add(a, b):
        """Add two numbers"""
        return a + b
    
    def multiply(x, y):
        """Multiply two numbers"""
        return x * y
    
    # Export for other languages
    export('py_add', add)
    export('py_multiply', multiply)
}

python {
    # Use functions within same language
    result1 = add(10, 20)
    result2 = multiply(5, 4)
    
    print(f"Python: 10 + 20 = {result1}")
    print(f"Python: 5 * 4 = {result2}")
    
    export('add_result', result1)
    export('multiply_result', result2)
}

javascript {
    // Call Python functions from JavaScript
    let sum = call('add', [15, 25]);
    let product = call('multiply', [3, 7]);
    
    console.log(`JavaScript: 15 + 25 = ${sum}`);
    console.log(`JavaScript: 3 * 7 = ${product}`);
}
