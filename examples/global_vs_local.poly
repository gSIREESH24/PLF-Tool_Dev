global {
    python {
        def add(a, b):
            return a + b
        
        def subtract(a, b):
            return a - b
        
        def greet(name):
            return f"Hello, {name}!"
    }
    javascript {
        function multiply(a, b) {
            return a * b;
        }
        
        function divide(a, b) {
            return b !== 0 ? a / b : 0;
        }
    }

    max_value = 100
    min_value = 0
}
python {
    def square(x):
        return x * x
    
    print("=== Python Block ===")
    print(add(10,30))
    print(f"Global add(10, 20) = {add(10, 20)}")
    print(f"Global subtract(50, 20) = {subtract(50, 20)}")
    print(f"Global greet('World') = {greet('World')}")
    
    print(f"Local square(7) = {square(7)}")
    
    print(f"Global max_value = {max_value}")
}

javascript {
    function power(base, exp) {
        return Math.pow(base, exp);
    }
    
    // Use local function
    console.log("\n=== JavaScript Block ===");
    console.log("Local multiply (5 * 6) = " + (5 * 6));
    console.log("Local divide (20 / 4) = " + (20 / 4));
    console.log("Local power(2, 3) = " + power(2, 3));
}

c {
    #include <stdio.h>
    
    int modulo(int a, int b) {
        return b != 0 ? a % b : 0;
    }
    
    int main() {
        printf("\n=== C Block ===\n");
        
        printf("Local modulo(17, 5) = %d\n", modulo(17, 5));
        printf("Local addition: 10 + 15 = %d\n", 10 + 15);
        
        return 0;
    }
}

python {
    print("\n=== Summary: What Functions Can Be Called? ===")
    
    print("\nGlobal Functions (accessible everywhere):")
    print(f"  Python: add(), subtract(), greet()")
    print(f"  JavaScript: multiply(), divide()")
    
    print("\nLocal Functions (language-specific):")
    print(f"  Python-only: square()")
    print(f"  JavaScript-only: power()")
    print(f"  C-only: modulo()")
    
    print("\nGlobal Variables:")
    print(f"  max_value = {max_value}")
    print(f"  min_value = {min_value}")
    
    print("\n[OK] Global functions defined in global block work everywhere!")
    print("[NO] Local functions stay in their own language")
}
