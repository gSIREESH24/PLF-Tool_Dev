global {
    class Employee {
        string name;
        int id;
        string department;
    }

    python {
        global_emp = Employee("Alice", 101, "Engineering")
        
        export("global_emp", global_emp)
    }
}

python {
    print("--- From Python ---")
    print(f"Global Employee: {global_emp['name']}, Dept: {global_emp['department']}")
    
    local_python_emp = Employee("Bob", 202, "HR")
    print(f"Local Python Employee: {local_python_emp.name}, Dept: {local_python_emp.department}")
}

javascript {
    console.log("--- From JavaScript ---");
    console.log("Global Employee: " + global_emp.name + ", Dept: " + global_emp.department);
    
    let local_js_emp = new Employee("Charlie", 303, "Marketing");
    console.log("Local JS Employee: " + local_js_emp.name + ", Dept: " + local_js_emp.department);
}

cpp {
    #include <iostream>
    #include <string>

    int main() {
        std::cout << "--- From C++ ---" << std::endl;
        
        Employee local_cpp_emp("David", 404, "Design");
        std::cout << "Local C++ Employee: " << local_cpp_emp.name << ", Dept: " << local_cpp_emp.department << std::endl;
        return 0;
    }
}

java {
    class Main {
        public static void main(String[] args) {
            System.out.println("--- From Java ---");
            
            Employee local_java_emp = new Employee("Eve", 505, "Sales");
            System.out.println("Local Java Employee: " + local_java_emp.name + ", Dept: " + local_java_emp.department);
        }
    }
}
